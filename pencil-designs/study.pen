    {
      "type": "note",
      "id": "Fqh5j",
      "x": -1790,
      "y": 2836.5,
      "name": "Dialog Interaction Notes",
      "width": 940,
      "height": 200,
      "content": "MODE SELECTION DIALOG\n\n• Triggered on: file picker load, drag & drop, deeplink open\n• Study Mode card: opens quiz in review/flashcard mode (no timer, no scoring)\n• Quiz Mode card: opens quiz in test mode (timed, scored)\n• Cancel: dismisses dialog, file is not opened\n• Selected card gets purple highlight border; unselected stays neutral\n• On mobile: dialog appears as bottom sheet or centered modal"
    },
    {
      "type": "note",
      "id": "pGajg",
      "x": -750,
      "y": 2836.5,
      "name": "Drag Overlay Interaction Notes",
      "width": 1940,
      "height": 200,
