          "pages": [
            {
              "components": [
                {
                  "type": "section_title",
                  "title": "Algebra: Quadratic Equations",
                  "subtitle": "Solving for x"
                },
                {
                  "type": "paragraph",
                  "title": "Definition",
                  "body": "A quadratic equation is any equation that can be rearranged in standard form as $ax^2 + bx + c = 0$ where x represents an unknown, and a, b, and c represent known numbers, where a ≠ 0."
                },
                {
                  "type": "formula",
                  "title": "The Quadratic Formula",
                  "equation": "x = \\frac{-b \\pm \\sqrt{b^2 - 4ac}}{2a}",
                  "equation_label": "Identifies the roots of the equation"
                },
                {
                  "type": "numbered_list",
                  "title": "Steps to use the formula",
                  "items": [
                    {
                      "title": "Standard Form",
                      "description": "Ensure the equation is in $ax^2 + bx + c = 0$ format."
                    },
                    {
                      "title": "Identify Coefficients",
                      "description": "Determine the values of a, b, and c."
                    },
                    {
                      "title": "Calculate Discriminant",
                      "description": "Find the value of $b^2 - 4ac$."
                    },
                    {
                      "title": "Solve",
                      "description": "Apply the rest of the formula to find x."
                    }
                  ]
                },
                {
                  "type": "reminder",
                  "body": "If the discriminant ($b^2 - 4ac$) is negative, the equation has no real solutions, only complex/imaginary ones!"
                }
              ]
            }
          ],
          "ai_summary": "A step-by-step guide to understanding and solving equations using the quadratic formula."
        },
