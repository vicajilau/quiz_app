                  "type": "icon_cards",
                  "title": "Key Circle Components",
                  "items": [
                    {
                      "title": "Radius (r)",
                      "description": "Distance from the center to any point on the circumference."
                    },
                    {
                      "title": "Diameter (d)",
                      "description": "A straight line segment that passes through the center of the circle and whose endpoints lie on the circle."
                    },
                    {
                      "title": "Circumference (C)",
                      "description": "The perimeter of the circle, calculated as $C = 2\\pi r$."
                    }
                  ]
                }
              ]
            }
          ],
          "ai_summary": "An explanation of the properties of a circle and how to correctly calculate its area using the radius."
