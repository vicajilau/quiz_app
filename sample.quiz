              "components": [
                {
                  "type": "section_title",
                  "title": "Understanding Prime Numbers",
                  "subtitle": "The Building Blocks of Arithmetic"
                },
                {
                  "type": "paragraph",
                  "title": "Introduction",
                  "body": "Prime numbers are numbers greater than 1 that have only two factors: 1 and themselves. They are foundational to number theory and cryptography."
                },
                {
                  "type": "key_definition",
                  "term": "Prime Number",
                  "body": "A whole number greater than 1 whose only divisors are 1 and itself."
                },
                {
                  "type": "key_concepts",
                  "title": "Rules of Primes",
                  "items": [
                    "Must be greater than 1",
                    "Has exactly two divisors",
                    "2 is the only even prime",
                    "1 is not prime"
                  ]
                },
                {
                  "type": "reminder",
                  "body": "Remember, the number 1 is neither prime nor composite!"
                }
              ]
            }
          ],
          "ai_summary": "A concise overview of prime numbers, their foundational rules, and practical examples."
        },
        {
          "chunk_index": 1,
          "status": "completed",
          "source_reference": {
            "document_id": "sample-doc-1",
            "start_page": 1,
            "end_page": 2,
            "start_offset": 101,
            "end_offset": 200,
            "block_type": "Neuroplasticity"
          },
          "pages": [
            {
              "components": [
                {
                  "type": "section_title",
                  "title": "Neuroplasticity and Learning",
                  "subtitle": "How the brain rewires itself"
                },
                {
                  "type": "paragraph",
                  "title": "Long-Term Potentiation",
                  "body": "Long-term potentiation (LTP) is a persistent strengthening of synapses based on recent patterns of activity. It is widely considered one of the major cellular mechanisms that underlies learning and memory."
                },
                {
                  "type": "key_definition",
                  "term": "Hebbian Learning",
                  "body": "A neuroscientific theory claiming that an increase in synaptic efficacy arises from a presynaptic cell's repeated and persistent stimulation of a postsynaptic cell. Often summarized as 'Cells that fire together, wire together.'"
                },
                {
                  "type": "pros_cons",
                  "title": "Impact of High Cognitive Demand",
                  "pros": [
                    "Increased synaptic density",
                    "Better memory retention",
                    "Enhanced cognitive flexibility"
                  ],
                  "cons": [
                    "High energy expenditure",
                    "Potential for cognitive fatigue",
                    "Slower initial processing during intense learning"
                  ]
                },
                {
                  "type": "quote",
                  "author": "Donald Hebb",
                  "body": "Neurons that fire together wire together."
                }
              ]
            }
          ],
          "ai_summary": "An explanation of Long-Term Potentiation (LTP) and Hebbian learning in the context of neuroplasticity."
        },
        {
          "chunk_index": 2,
          "status": "completed",
